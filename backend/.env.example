# --- Server ---
PORT=4000
NODE_ENV=production
# Comma-separated list of allowed origins for CORS
CORS_ORIGIN=https://secretvoip.com

# --- Auth ---
# IMPORTANT: change to a long random string in production
JWT_SECRET=replace-with-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# --- Database ---
DATABASE_URL=postgres://svm_user:svm_password@localhost:5432/secretvoip_mail

# --- Upstream Mail Provider (NEVER exposed to frontend) ---
MAIL_PROVIDER_BASE_URL=https://secret.zspoof.com
MAIL_PROVIDER_API_KEY=

# --- Pricing (EUR per accepted email) ---
PRICE_PER_EMAIL=0.003

# --- Initial admin (used by `npm run seed:admin`) ---
ADMIN_EMAIL=admin@secretvoip.com
ADMIN_PASSWORD=change-me-immediately
ADMIN_NAME=Super Admin
